# LiveKit Cloud Credentials
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Google AI Studio API Key (used for LLM, STT, and TTS if using AI Studio API)
GOOGLE_API_KEY=AIzaSy...

# Google Cloud Service Account (used for Vertex AI and Enterprise features)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Options: in_memory (default for local prototyping), vertex_ai (Vertex AI RAG Corpus), firestore (Strategy A)
MEMORY_SERVICE_TYPE=in_memory
GEMINI_MODEL_ID=gemini-3.1-flash-live-preview

# Vertex AI RAG Configuration (only required if MEMORY_SERVICE_TYPE=vertex_ai)
# RAG_CORPUS_ID=projects/YOUR_PROJECT_ID/locations/us-central1/ragCorpora/YOUR_CORPUS_ID

# GCP Firestore & Cloud Storage & Pub/Sub Configuration (required if MEMORY_SERVICE_TYPE=firestore)
# GCP_PROJECT_ID=your-gcp-project-id
# GCS_BUCKET_NAME=your-gcs-bucket-name
# PUBSUB_TOPIC_NAME=your-pubsub-topic-name
# FIRESTORE_COLLECTION=memories
# GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

